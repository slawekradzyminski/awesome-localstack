{
  "realm": "awesome-testing",
  "enabled": true,
  "sslRequired": "none",
  "displayName": "Awesome Testing",
  "clients": [
    {
      "clientId": "awesome-testing-frontend",
      "name": "Awesome Testing Frontend",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:8081/auth/sso/callback"
      ],
      "webOrigins": [
        "http://localhost:8081"
      ],
      "rootUrl": "http://localhost:8081",
      "baseUrl": "http://localhost:8081",
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:8081/login"
      },
      "protocolMappers": [
        {
          "name": "identity-provider",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usersessionmodel-note-mapper",
          "consentRequired": false,
          "config": {
            "user.session.note": "identity_provider",
            "id.token.claim": "true",
            "access.token.claim": "false",
            "claim.name": "identity_provider",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
  "identityProviders": [
    {
      "alias": "google",
      "displayName": "Google",
      "providerId": "oidc",
      "enabled": true,
      "trustEmail": true,
      "storeToken": false,
      "addReadTokenRoleOnCreate": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "issuer": "http://localhost:8082/realms/google-mock",
        "authorizationUrl": "http://localhost:8082/realms/google-mock/protocol/openid-connect/auth",
        "tokenUrl": "http://localhost:8080/realms/google-mock/protocol/openid-connect/token",
        "jwksUrl": "http://localhost:8080/realms/google-mock/protocol/openid-connect/certs",
        "userInfoUrl": "http://localhost:8080/realms/google-mock/protocol/openid-connect/userinfo",
        "logoutUrl": "http://localhost:8080/realms/google-mock/protocol/openid-connect/logout",
        "clientId": "keycloak-broker",
        "clientSecret": "keycloak-broker-secret",
        "clientAuthMethod": "client_secret_post",
        "defaultScope": "openid email profile",
        "syncMode": "FORCE",
        "validateSignature": "true",
        "useJwksUrl": "true"
      }
    },
    {
      "alias": "github",
      "displayName": "GitHub",
      "providerId": "oidc",
      "enabled": true,
      "trustEmail": true,
      "storeToken": false,
      "addReadTokenRoleOnCreate": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "issuer": "http://localhost:8082/realms/github-mock",
        "authorizationUrl": "http://localhost:8082/realms/github-mock/protocol/openid-connect/auth",
        "tokenUrl": "http://localhost:8080/realms/github-mock/protocol/openid-connect/token",
        "jwksUrl": "http://localhost:8080/realms/github-mock/protocol/openid-connect/certs",
        "userInfoUrl": "http://localhost:8080/realms/github-mock/protocol/openid-connect/userinfo",
        "logoutUrl": "http://localhost:8080/realms/github-mock/protocol/openid-connect/logout",
        "clientId": "keycloak-broker",
        "clientSecret": "keycloak-broker-secret",
        "clientAuthMethod": "client_secret_post",
        "defaultScope": "openid email profile",
        "syncMode": "FORCE",
        "validateSignature": "true",
        "useJwksUrl": "true"
      }
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "client"
      },
      {
        "name": "admin"
      }
    ]
  },
  "users": [
    {
      "username": "sso-client",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Sso",
      "lastName": "Client",
      "email": "sso-client@example.test",
      "realmRoles": [
        "client"
      ],
      "credentials": [
        {
          "type": "password",
          "value": "SsoClient123!",
          "temporary": false
        }
      ]
    },
    {
      "username": "sso-admin",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Sso",
      "lastName": "Admin",
      "email": "sso-admin@example.test",
      "realmRoles": [
        "client",
        "admin"
      ],
      "credentials": [
        {
          "type": "password",
          "value": "SsoAdmin123!",
          "temporary": false
        }
      ]
    }
  ]
}
